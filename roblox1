            status.TextColor3 = colors.toggleOn
        else
            btn.BackgroundColor3 = colors.panelLight
            status.Text = "OFF"
            status.TextColor3 = colors.textDim
        end
        callback(enabled)
    end)

    return {btn = btn, status = status}
end

local function createSlider(text, min, max, default, callback, suffix)
    suffix = suffix or ""
    local container = Instance.new("Frame")
    container.Name = text .. "Slider"
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 50)
    container.Parent = functionsScrolling

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.Text = text
    label.TextColor3 = colors.text
    label.TextSize = 14
    label.Position = UDim2.new(0, 5, 0, 0)
    label.Size = UDim2.new(1, -70, 0, 22)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    local valueLabel = Instance.new("TextLabel")
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.Text = tostring(default) .. suffix
    valueLabel.TextColor3 = colors.accentLight
    valueLabel.TextSize = 14
    valueLabel.Position = UDim2.new(1, -70, 0, 0)
    valueLabel.Size = UDim2.new(0, 70, 0, 22)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.Parent = container

    local sliderBg = Instance.new("Frame")
    sliderBg.BackgroundColor3 = colors.panelLight
    sliderBg.Position = UDim2.new(0, 5, 0, 28)
    sliderBg.Size = UDim2.new(1, -10, 0, 6)
    sliderBg.Parent = container

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 3)
    bgCorner.Parent = sliderBg

    local slider = Instance.new("Frame")
    slider.BackgroundColor3 = colors.accentLight
    slider.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    slider.Parent = sliderBg

    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 3)
    sliderCorner.Parent = slider

    local dragButton = Instance.new("TextButton")
    dragButton.BackgroundTransparency = 1
    dragButton.Size = UDim2.new(1, 0, 1, 0)
    dragButton.Text = ""
    dragButton.Parent = sliderBg

    local value = default
    local dragging = false

    dragButton.MouseButton1Down:Connect(function() dragging = true end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UIS:GetMouseLocation()
            local absPos = sliderBg.AbsolutePosition
            local size = sliderBg.AbsoluteSize.X
            local relative = math.clamp((mousePos.X - absPos.X) / size, 0, 1)
            slider.Size = UDim2.new(relative, 0, 1, 0)
            value = min + (max - min) * relative
            value = math.floor(value * 100) / 100
            valueLabel.Text = tostring(value) .. suffix
            callback(value)
        end
    end)

    return container
end

