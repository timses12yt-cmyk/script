function updateFunctions()
    for _, child in ipairs(functionsScrolling:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end
    
    if currentModule == "COMBAT" then
        createToggle("Aimbot", function() return aimbotEnabled end, function(v) aimbotEnabled = v end)
        createSlider("Скорость аима", 0.1, 1, function() return aimbotSpeed end, function(v) aimbotSpeed = v end, "")
        createSlider("FOV", 30, 180, function() return aimbotFOV end, function(v) aimbotFOV = v end, "°")
        
    elseif currentModule == "MOVEMENT" then
        createToggle("Fly", function() return flyEnabled end, function(v) flyEnabled = v updateFly() end)
        createSlider("Скорость полета", 10, 200, function() return flySpeed end, function(v) flySpeed = v end, "")
        createToggle("Noclip", function() return noclipEnabled end, function(v) noclipEnabled = v end)
        createToggle("Inf Jump", function() return infJumpEnabled end, function(v) infJumpEnabled = v end)
        createToggle("Speed", function() return speedEnabled end, function(v) speedEnabled = v end)
        createSlider("Speed Power", 10, 200, function() return speedPower end, function(v) speedPower = v end, "")
        createToggle("Jump Power", function() return jumpEnabled end, function(v) jumpEnabled = v end)
        createSlider("Jump Power", 10, 200, function() return jumpPower end, function(v) jumpPower = v end, "")
        
    elseif currentModule == "VISUALS" then
        createToggle("Fullbright", function() return fullbrightEnabled end, function(v) fullbrightEnabled = v updateFullbright() end)
        createToggle("Blur", function() return blurEnabled end, function(v) blurEnabled = v updateBlur() end)
        createToggle("No Fog", function() return noFogEnabled end, function(v) noFogEnabled = v updateNoFog() end)
        
    elseif currentModule == "PLAYER" then
        createToggle("F+Click TP", function() return clickTpEnabled end, function(v) clickTpEnabled = v end)
