function updateFunctions()
    for _, child in ipairs(functionsScrolling:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end
    
    if currentModule == "COMBAT" then
        createToggle("Aimbot", function() return aimbotEnabled end, function(v) aimbotEnabled = v end)
        createSlider("Скорость аима", 0.1, 1, function() return aimbotSpeed end, function(v) aimbotSpeed = v end, "")
        createSlider("FOV", 30, 180, function() return aimbotFOV end, function(v) aimbotFOV = v end, "°")
        
    elseif currentModule == "MOVEMENT" then
        createToggle("Fly", function() return flyEnabled end, function(v) flyEnabled = v updateFly() end)
        createSlider("Скорость полета", 10, 200, function() return flySpeed end, function(v) flySpeed = v end, "")
        createToggle("Noclip", function() return noclipEnabled end, function(v) noclipEnabled = v end)
        createToggle("Inf Jump", function() return infJumpEnabled end, function(v) infJumpEnabled = v end)
        createToggle("Speed", function() return speedEnabled end, function(v) speedEnabled = v end)
        createSlider("Speed Power", 10, 200, function() return speedPower end, function(v) speedPower = v end, "")
        createToggle("Jump Power", function() return jumpEnabled end, function(v) jumpEnabled = v end)
        createSlider("Jump Power", 10, 200, function() return jumpPower end, function(v) jumpPower = v end, "")
        
    elseif currentModule == "VISUALS" then
        createToggle("Fullbright", function() return fullbrightEnabled end, function(v) fullbrightEnabled = v updateFullbright() end)
        createToggle("Blur", function() return blurEnabled end, function(v) blurEnabled = v updateBlur() end)
        createToggle("No Fog", function() return noFogEnabled end, function(v) noFogEnabled = v updateNoFog() end)
        
    elseif currentModule == "PLAYER" then
        createToggle("F+Click TP", function() return clickTpEnabled end, function(v) clickTpEnabled = v end)
        createToggle("God Mode", function() return godModeEnabled end, function(v) godModeEnabled = v end)
        createToggle("Infinite Ammo", function() return infiniteAmmoEnabled end, function(v) infiniteAmmoEnabled = v end)
        
        local killBtn = Instance.new("TextButton")
        killBtn.Size = UDim2.new(1, 0, 0, 40)
        killBtn.BackgroundColor3 = colors.danger
        killBtn.Text = "💀 KILL YOURSELF"
        killBtn.TextColor3 = Color3.new(1,1,1)
        killBtn.TextSize = 14
        killBtn.Font = Enum.Font.GothamBold
        killBtn.Parent = functionsScrolling
        
        local killCorner = Instance.new("UICorner")
        killCorner.CornerRadius = UDim.new(0, 8)
        killCorner.Parent = killBtn
        
        killBtn.MouseButton1Click:Connect(function()
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.Health = 0
            end
        end)
        
    elseif currentModule == "ESP" then
        createToggle("ESP", function() return espEnabled end, function(v) espEnabled = v updateESP() end)
        
    elseif currentModule == "MISC" then
        createToggle("Particles", function() return particlesEnabled end, function(v) particlesEnabled = v updateParticles() end)
        createToggle("Auto Attack", function() return autoAttackEnabled end, function(v) autoAttackEnabled = v end)
        createSlider("Attack Range", 5, 50, function() return autoAttackRange end, function(v) autoAttackRange = v end, "")
        
        local unhookBtn = Instance.new("TextButton")
        unhookBtn.Size = UDim2.new(1, 0, 0, 45)
        unhookBtn.BackgroundColor3 = colors.danger
        unhookBtn.Text = "🔌 UNHOOK (ПОЛНАЯ ВЫГРУЗКА)"
        unhookBtn.TextColor3 = Color3.new(1, 1, 1)
        unhookBtn.TextSize = 14
        unhookBtn.Font = Enum.Font.GothamBold
        unhookBtn.Parent = functionsScrolling
        
        local unhookCorner = Instance.new("UICorner")
        unhookCorner.CornerRadius = UDim.new(0, 8)
        unhookCorner.Parent = unhookBtn
        
        unhookBtn.MouseButton1Click:Connect(function()
            unhook()
        end)
        
    elseif currentModule == "FRIENDS" then
        local friendNote = Instance.new("TextLabel")
        friendNote.Size = UDim2.new(1, 0, 0, 30)
        friendNote.BackgroundTransparency = 1
        friendNote.Text = "👥 СПИСОК ДРУЗЕЙ"
        friendNote.TextColor3 = colors.accentLight
        friendNote.TextSize = 16
        friendNote.Font = Enum.Font.GothamBold
        friendNote.Parent = functionsScrolling
        
        local friendList = Instance.new("ScrollingFrame")
        friendList.Size = UDim2.new(1, 0, 0, 200)
        friendList.BackgroundColor3 = colors.panelLight
        friendList.BorderSizePixel = 0
        friendList.CanvasSize = UDim2.new(0, 0, 0, 0)
        friendList.ScrollBarThickness = 4
        friendList.AutomaticCanvasSize = Enum.AutomaticSize.Y
        friendList.Parent = functionsScrolling
        
        local friendLayout = Instance.new("UIListLayout")
        friendLayout.Parent = friendList
        friendLayout.Padding = UDim.new(0, 2)
        
        local function updateFriendList()
            for _, child in ipairs(friendList:GetChildren()) do
                if child:IsA("Frame") then child:Destroy() end
            end
            
            for userId, name in pairs(friends) do
                local container = Instance.new("Frame")
                container.Size = UDim2.new(1, -10, 0, 35)
                container.BackgroundColor3 = colors.panel
                container.Parent = friendList
                
                local containerCorner = Instance.new("UICorner")
                containerCorner.CornerRadius = UDim.new(0, 6)
                containerCorner.Parent = container
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -60, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = name
                nameLabel.TextColor3 = colors.text
                nameLabel.TextSize = 14
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = container
                
                local removeBtn = Instance.new("TextButton")
                removeBtn.Size = UDim2.new(0, 50, 1, -10)
                removeBtn.Position = UDim2.new(1, -55, 0, 5)
                removeBtn.BackgroundColor3 = colors.danger
                removeBtn.Text = "✕"
                removeBtn.TextColor3 = Color3.new(1,1,1)
                removeBtn.TextSize = 14
                removeBtn.Parent = container
                
                local removeCorner = Instance.new("UICorner")
                removeCorner.CornerRadius = UDim.new(0, 4)
                removeCorner.Parent = removeBtn
                
                removeBtn.MouseButton1Click:Connect(function()
                    friends[userId] = nil
                    saveData()
                    updateFriendList()
                    if espEnabled then updateESP() end
                end)
            end
        end
        
        updateFriendList()
        
        local addFriendInput = Instance.new("TextBox")
        addFriendInput.Size = UDim2.new(1, 0, 0, 40)
        addFriendInput.BackgroundColor3 = colors.panelLight
        addFriendInput.PlaceholderText = "Введите имя игрока"
        addFriendInput.PlaceholderColor3 = colors.textDim
        addFriendInput.Text = ""
        addFriendInput.TextColor3 = colors.text
        addFriendInput.Parent = functionsScrolling
        
        local addCorner = Instance.new("UICorner")
        addCorner.CornerRadius = UDim.new(0, 8)
        addCorner.Parent = addFriendInput
        
        local addBtn = Instance.new("TextButton")
        addBtn.Size = UDim2.new(1, 0, 0, 40)
        addBtn.BackgroundColor3 = colors.friend
        addBtn.Text = "➕ ДОБАВИТЬ В ДРУЗЬЯ"
        addBtn.TextColor3 = Color3.new(1,1,1)
        addBtn.TextSize = 14
        addBtn.Font = Enum.Font.GothamBold
        addBtn.Parent = functionsScrolling
        
        local addBtnCorner = Instance.new("UICorner")
        addBtnCorner.CornerRadius = UDim.new(0, 8)
        addBtnCorner.Parent = addBtn
        
        addBtn.MouseButton1Click:Connect(function()
            local targetName = addFriendInput.Text
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name:lower():find(targetName:lower()) or p.DisplayName:lower():find(targetName:lower()) then
                    friends[p.UserId] = p.Name
                    saveData()
                    updateFriendList()
                    if espEnabled then updateESP() end
                    addFriendInput.Text = ""
                    break
                end
            end
        end)
        
        createToggle("ESP для друзей", function() return friendEspEnabled end, function(v) friendEspEnabled = v end)
        
    elseif currentModule == "TELEPORT" then
        local tpNote = Instance.new("TextLabel")
        tpNote.Size = UDim2.new(1, 0, 0, 30)
        tpNote.BackgroundTransparency = 1
        tpNote.Text = "📍 ТОЧКИ ТЕЛЕПОРТАЦИИ"
        tpNote.TextColor3 = colors.accentLight
        tpNote.TextSize = 16
        tpNote.Font = Enum.Font.GothamBold
        tpNote.Parent = functionsScrolling
        
        -- Список точек
        local pointsList = Instance.new("ScrollingFrame")
        pointsList.Size = UDim2.new(1, 0, 0, 200)
        pointsList.BackgroundColor3 = colors.panelLight
        pointsList.BorderSizePixel = 0
        pointsList.CanvasSize = UDim2.new(0, 0, 0, 0)
        pointsList.ScrollBarThickness = 4
        pointsList.AutomaticCanvasSize = Enum.AutomaticSize.Y
        pointsList.Parent = functionsScrolling
        
        local pointsLayout = Instance.new("UIListLayout")
        pointsLayout.Parent = pointsList
        pointsLayout.Padding = UDim.new(0, 2)
        
        local function updatePointsList()
            for _, child in ipairs(pointsList:GetChildren()) do
                if child:IsA("Frame") then child:Destroy() end
            end
            
            for i, point in ipairs(teleportPoints) do
                local container = Instance.new("Frame")
                container.Size = UDim2.new(1, -10, 0, 45)
                container.BackgroundColor3 = (selectedTeleportPoint == point) and colors.accent or colors.panel
                container.Parent = pointsList
                
                local containerCorner = Instance.new("UICorner")
                containerCorner.CornerRadius = UDim.new(0, 6)
                containerCorner.Parent = container
                
                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(1, -120, 0, 20)
                nameLabel.Position = UDim2.new(0, 10, 0, 5)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = point.name
                nameLabel.TextColor3 = colors.text
                nameLabel.TextSize = 14
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = container
                
                local coordsLabel = Instance.new("TextLabel")
                coordsLabel.Size = UDim2.new(1, -120, 0, 16)
                coordsLabel.Position = UDim2.new(0, 10, 0, 25)
                coordsLabel.BackgroundTransparency = 1
                coordsLabel.Text = string.format("X:%.0f Y:%.0f Z:%.0f", point.pos.X, point.pos.Y, point.pos.Z)
                coordsLabel.TextColor3 = colors.textDim
                coordsLabel.TextSize = 11
                coordsLabel.TextXAlignment = Enum.TextXAlignment.Left
                coordsLabel.Parent = container
                
                local tpBtn = Instance.new("TextButton")
                tpBtn.Size = UDim2.new(0, 50, 1, -10)
                tpBtn.Position = UDim2.new(1, -110, 0, 5)
                tpBtn.BackgroundColor3 = colors.accentLight
                tpBtn.Text = "TP"
                tpBtn.TextColor3 = Color3.new(1,1,1)
                tpBtn.TextSize = 12
                tpBtn.Parent = container
                
                local tpCorner = Instance.new("UICorner")
                tpCorner.CornerRadius = UDim.new(0, 4)
                tpCorner.Parent = tpBtn
                
                local delBtn = Instance.new("TextButton")
                delBtn.Size = UDim2.new(0, 50, 1, -10)
                delBtn.Position = UDim2.new(1, -55, 0, 5)
                delBtn.BackgroundColor3 = colors.danger
                delBtn.Text = "✕"
                delBtn.TextColor3 = Color3.new(1,1,1)
                delBtn.TextSize = 14
                delBtn.Parent = container
                
                local delCorner = Instance.new("UICorner")
                delCorner.CornerRadius = UDim.new(0, 4)
                delCorner.Parent = delBtn
                
                container.MouseButton1Click:Connect(function()
                    selectedTeleportPoint = point
                    updatePointsList()
                end)
                
                tpBtn.MouseButton1Click:Connect(function()
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        player.Character.HumanoidRootPart.CFrame = CFrame.new(point.pos)
                    end
                end)
                
                delBtn.MouseButton1Click:Connect(function()
                    for j, p in ipairs(teleportPoints) do
                        if p == point then
                            table.remove(teleportPoints, j)
                            if selectedTeleportPoint == point then selectedTeleportPoint = nil end
                            saveData()
                            updatePointsList()
                            break
                        end
                    end
                end)
            end
        end
        
        updatePointsList()
        
        -- Добавление новой точки
        local pointNameInput = Instance.new("TextBox")
        pointNameInput.Size = UDim2.new(1, 0, 0, 40)
        pointNameInput.BackgroundColor3 = colors.panelLight
        pointNameInput.PlaceholderText = "Название точки"
        pointNameInput.PlaceholderColor3 = colors.textDim
        pointNameInput.Text = ""
        pointNameInput.TextColor3 = colors.text
        pointNameInput.Parent = functionsScrolling
        
        local nameCorner = Instance.new("UICorner")
        nameCorner.CornerRadius = UDim.new(0, 8)
        nameCorner.Parent = pointNameInput
        
        local saveBtn = Instance.new("TextButton")
        saveBtn.Size = UDim2.new(1, 0, 0, 40)
        saveBtn.BackgroundColor3 = colors.success
        saveBtn.Text = "💾 СОХРАНИТЬ ТЕКУЩУЮ ТОЧКУ"
        saveBtn.TextColor3 = Color3.new(1,1,1)
        saveBtn.TextSize = 14
        saveBtn.Font = Enum.Font.GothamBold
        saveBtn.Parent = functionsScrolling
        
        local saveCorner = Instance.new("UICorner")
        saveCorner.CornerRadius = UDim.new(0, 8)
        saveCorner.Parent = saveBtn
        
        saveBtn.MouseButton1Click:Connect(function()
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local name = pointNameInput.Text
                if name == "" then
                    name = "Точка #" .. (#teleportPoints + 1)
                end
                local pos = player.Character.HumanoidRootPart.Position
                table.insert(teleportPoints, {
                    name = name,
                    pos = Vector3.new(pos.X, pos.Y, pos.Z)
                })
                saveData()
                updatePointsList()
                pointNameInput.Text = ""
            end
        end)
        
    elseif currentModule == "THEME" then
        createSlider("Затемнение фона", 0, 1, function() return bgTransparency end, function(v) bgTransparency = v bgDim.BackgroundTransparency = v end, "")
    end
end

-- ===== СОЗДАНИЕ КНОПОК МОДУЛЕЙ =====
for _, module in ipairs(modules) do
    createModuleButton(module)
end

-- Инициализация
updateFunctions()

-- Автосохранение данных
spawn(function()
    while true do
        wait(60)
        saveData()
    end
end)

-- Обновление ESP при добавлении/удалении игроков
Players.PlayerAdded:Connect(function()
    if espEnabled then wait(0.5) updateESP() end
end)

Players.PlayerRemoving:Connect(function()
    if espEnabled then wait(0.5) updateESP() end
end)

-- Горячие клавиши
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if input.KeyCode == Enum.KeyCode.F8 then
        unhook()
        return
    end
    
    if input.KeyCode == Enum.KeyCode.M then
        uiContainer.Visible = not uiContainer.Visible
        bgDim.Visible = uiContainer.Visible
        return
    end
    
    if input.KeyCode == Enum.KeyCode.Insert then
        uiContainer.Visible = not uiContainer.Visible
        bgDim.Visible = uiContainer.Visible
    end
end)

