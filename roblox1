local function modifyWeaponAmmo(weapon)
    local ammo = weapon:FindFirstChild("Ammo")
    local maxAmmo = weapon:FindFirstChild("MaxAmmo")
    if ammo then ammo.Value = 999999 end
    if maxAmmo then maxAmmo.Value = 999999 end
end

RunService.Heartbeat:Connect(function()
    if infiniteAmmoEnabled and player.Character then
        for _, tool in ipairs(player.Backpack:GetChildren()) do
            if tool:IsA("Tool") then modifyWeaponAmmo(tool) end
        end
        for _, tool in ipairs(player.Character:GetChildren()) do
            if tool:IsA("Tool") then modifyWeaponAmmo(tool) end
        end
    end
end)

-- AUTO ATTACK
RunService.Heartbeat:Connect(function()
    if autoAttackEnabled and player.Character then
        local myPos = player.Character:FindFirstChild("HumanoidRootPart")
        if not myPos then return end
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (myPos.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist <= autoAttackRange then
                    for _, tool in ipairs(player.Character:GetChildren()) do
                        if tool:IsA("Tool") then
                            tool:Activate()
                        end
                    end
                    break
                end
            end
        end
    end
end)

-- PARTICLES
local particleConnection = nil
local function createParticle()
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local pos = hrp.Position + Vector3.new(
        math.random(-50, 50),
        math.random(-20, 50),
        math.random(-50, 50)
    )
    
    local ball = Instance.new("Part")
    ball.Size = Vector3.new(0.5, 0.5, 0.5)
    ball.Position = pos
    ball.Anchored = false
    ball.CanCollide = false
    ball.Transparency = 0.2
    ball.BrickColor = BrickColor.new(Color3.fromRGB(100, 200, 255))
    ball.Material = Enum.Material.Neon
    ball.Shape = Enum.PartType.Ball
    ball.Parent = Workspace
    
    ball.Velocity = Vector3.new(math.random(-5,5), math.random(-5,5), math.random(-5,5))
    Debris:AddItem(ball, 3)
end

local function updateParticles()
    if particleConnection then particleConnection:Disconnect() particleConnection = nil end
    if particlesEnabled then
        particleConnection = RunService.Heartbeat:Connect(function()
            if math.random() < 0.2 then createParticle() end
        end)
    end
end

-- ESP
local espObjects = {}
local function updateESP()
    for _, obj in ipairs(espObjects) do
        pcall(function() obj:Destroy() end)
    end
    espObjects = {}
    
    if not espEnabled then return end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local highlight = Instance.new("Highlight")
            highlight.Parent = p.Character
            highlight.FillColor = Color3.fromRGB(255, 80, 80)
            highlight.FillTransparency = 0.5
            highlight.OutlineColor = Color3.fromRGB(255, 80, 80)
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            table.insert(espObjects, highlight)
        end
    end
end

