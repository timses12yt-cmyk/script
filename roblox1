local configFileName = "Nez0xConfig.json"

local function saveConfig()
    local data = {
        friends = friends,
        teleportPoints = teleportPoints,
        colors = colors,
        guiSize = guiSize,
        particleSettings = particleSettings,
        espMode = espMode,
        settings = {
            bgTransparency = bgTransparency,
            aimbotSpeed = aimbotSpeed,
            aimbotRandom = aimbotRandom,
            flySpeed = flySpeed,
            speedPower = speedPower,
            jumpPower = jumpPower,
            autoAttackRange = autoAttackRange,
        }
    }
    local success = pcall(function()
        writefile(configFileName, HttpService:JSONEncode(data))
    end)
    if success then
        print("✅ Конфиг сохранен")
    end
end

local function loadConfig()
    local success, data = pcall(function()
        return readfile(configFileName)
    end)
    if success and data then
        local decoded = HttpService:JSONDecode(data)
        if decoded then
            friends = decoded.friends or {}
            teleportPoints = decoded.teleportPoints or {}
            guiSize = decoded.guiSize or 1.0
            particleSettings = decoded.particleSettings or particleSettings
            espMode = decoded.espMode or "Все"
            
            if decoded.colors then
                for k, v in pairs(decoded.colors) do
                    colors[k] = Color3.new(v.R, v.G, v.B)
                end
            end
            
            if decoded.settings then
                bgTransparency = decoded.settings.bgTransparency or 0.7
                aimbotSpeed = decoded.settings.aimbotSpeed or 0.5
                aimbotRandom = decoded.settings.aimbotRandom or 0.1
                flySpeed = decoded.settings.flySpeed or 50
                speedPower = decoded.settings.speedPower or 50
                jumpPower = decoded.settings.jumpPower or 100
                autoAttackRange = decoded.settings.autoAttackRange or 20
            end
        end
    end
end

