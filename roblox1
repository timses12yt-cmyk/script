-- Aimbot
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Thickness = 2
fovCircle.NumSides = 60
fovCircle.Filled = false
fovCircle.Color = Color3.fromRGB(255, 255, 255)

RunService.RenderStepped:Connect(function()
    if features.aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and player.Character then
        local closest = nil
        local shortest = math.huge
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                local dist = (player.Character.HumanoidRootPart.Position - p.Character.Head.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = p.Character.Head
                end
            end
        end
        
        if closest then
            Workspace.CurrentCamera.CFrame = Workspace.CurrentCamera.CFrame:Lerp(
                CFrame.new(Workspace.CurrentCamera.CFrame.Position, closest.Position), 
                features.aimbotSpeed
            )
        end
    end
end)

-- Auto Attack
RunService.Heartbeat:Connect(function()
    if features.autoAttack and player.Character then
        local target = nil
        local myPos = player.Character:FindFirstChild("HumanoidRootPart")
        if not myPos then return end
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (myPos.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist <= features.autoAttackRange then
                    target = p
                    break
                end
            end
        end
        
        if target and target.Character then
            for _, tool in ipairs(player.Character:GetChildren()) do
                if tool:IsA("Tool") then
                    tool:Activate()
                end
            end
        end
    end
end)

-- Particles
local particleConnection = nil
local function createParticle()
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local pos = hrp.Position + Vector3.new(
        math.random(-50, 50),
        math.random(-20, 50),
        math.random(-50, 50)
    )
    
    local ball = Instance.new("Part")
    ball.Size = Vector3.new(0.5, 0.5, 0.5)
    ball.Position = pos
    ball.Anchored = false
    ball.CanCollide = false
    ball.Transparency = 0.2
    ball.BrickColor = BrickColor.new(Color3.fromRGB(100, 200, 255))
    ball.Material = Enum.Material.Neon
    ball.Shape = Enum.PartType.Ball
    ball.Parent = Workspace
    
    ball.Velocity = Vector3.new(math.random(-5,5), math.random(-5,5), math.random(-5,5))
    Debris:AddItem(ball, 3)
end

local function toggleParticles(state)
    features.particles = state
    if particleConnection then particleConnection:Disconnect() particleConnection = nil end
    if state then
        particleConnection = RunService.Heartbeat:Connect(function()
            if math.random() < 0.2 then createParticle() end
        end)
    end
end

-- Функция полной выгрузки (UNHOOK)
local function unhook()
    -- Отключаем все соединения
    if flyConnection then flyConnection:Disconnect() end
    if particleConnection then particleConnection:Disconnect() end
    
    -- Удаляем эффекты
    if blurEffect then blurEffect:Destroy() end
    
    -- Удаляем GUI
    if gui then gui:Destroy() end
    
    -- Очищаем Drawing объекты
    if fovCircle then fovCircle:Remove() end
    
    print("✅ Nez0x UI полностью выгружен")
end

