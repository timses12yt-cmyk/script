-- Aimbot
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Thickness = 2
fovCircle.NumSides = 60
fovCircle.Filled = false
fovCircle.ZIndex = 999999

local function addRandomness(target, amount)
    if amount <= 0 then return target end
    local offset = Vector3.new(
        (math.random()*2-1)*amount,
        (math.random()*2-1)*amount,
        (math.random()*2-1)*amount
    )
    return target + offset
end

RunService.RenderStepped:Connect(function()
    if features.aimbot then
        fovCircle.Visible = features.aimbotShowFOV
        fovCircle.Radius = features.aimbotFOV
        fovCircle.Position = UIS:GetMouseLocation()
        fovCircle.Color = features.aimbotShowFOV and Color3.fromRGB(255,255,255) or Color3.new()
        
        if UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and player.Character then
            local closest, shortest = nil, math.huge
            local mousePos = UIS:GetMouseLocation()
            
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                    if features.teamCheck then
                        if p.Team and player.Team and p.Team == player.Team then continue end
                    end
                    
                    if features.aimbotShowFOV then
                        local headPos, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(p.Character.Head.Position)
                        if onScreen then
                            local dist = (Vector2.new(headPos.X, headPos.Y) - mousePos).Magnitude
                            if dist > features.aimbotFOV then continue end
                        end
                    end
                    
                    local dist = (player.Character.HumanoidRootPart.Position - p.Character.Head.Position).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = p.Character.Head
                    end
                end
            end
            
            if closest then
                local target = addRandomness(closest.Position, features.aimbotRandomness)
                Workspace.CurrentCamera.CFrame = Workspace.CurrentCamera.CFrame:Lerp(
                    CFrame.new(Workspace.CurrentCamera.CFrame.Position, target), 
                    features.aimbotSpeed
                )
            end
        end
    else
        fovCircle.Visible = false
    end
end)

-- Auto Attack
local function findClosestEnemy(range)
    local closest, closestDist = nil, range
    local myPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not myPos then return nil end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if features.teamCheck then
                if p.Team and player.Team and p.Team == player.Team then continue end
            end
            local dist = (myPos.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist <= closestDist then
                closest, closestDist = p, dist
            end
        end
    end
    return closest
end

RunService.Heartbeat:Connect(function()
    if features.autoAttack and player.Character then
        local target = findClosestEnemy(features.autoAttackRange)
        if target and target.Character then
            local hrp = target.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                Workspace.CurrentCamera.CFrame = CFrame.lookAt(Workspace.CurrentCamera.CFrame.Position, hrp.Position)
                for _, tool in ipairs(player.Character:GetChildren()) do
                    if tool:IsA("Tool") then
                        tool:Activate()
                        for _, event in ipairs(tool:GetDescendants()) do
                            if event:IsA("RemoteEvent") then pcall(function() event:FireServer("Activate") end) end
                        end
                    end
                end
            end
        end
    end
end)

-- Particles
local particles = {}
local particleConnection = nil

local function createParticle()
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local angle = math.random() * 2 * math.pi
    local radius = math.random(30, 100)
    local height = math.random(-50, 50)
    
    local pos = hrp.Position + Vector3.new(math.cos(angle)*radius, height+10, math.sin(angle)*radius)
    
    local ball = Instance.new("Part")
    ball.Size = Vector3.new(0.5, 0.5, 0.5)
    ball.Position = pos
    ball.Anchored = false
    ball.CanCollide = false
    ball.Transparency = 0.2
    ball.BrickColor = BrickColor.new(Color3.fromRGB(100, math.random(150,255), 255))
    ball.Material = Enum.Material.Neon
    ball.Shape = Enum.PartType.Ball
    ball.Parent = Workspace
    
    local light = Instance.new("PointLight")
    light.Parent = ball
    light.Color = Color3.fromRGB(100, 200, 255)
    light.Range = 8
    light.Brightness = 2
    
    ball.Velocity = Vector3.new(math.random(-10,10), math.random(-5,5), math.random(-10,10))
    
    Debris:AddItem(ball, 5)
    Debris:AddItem(light, 5)
end

local function toggleParticles(state)
    features.particles = state
    if particleConnection then particleConnection:Disconnect() particleConnection = nil end
    if state then
        particleConnection = RunService.Heartbeat:Connect(function()
            if math.random() < 0.3 then createParticle() end
        end)
    end
end

