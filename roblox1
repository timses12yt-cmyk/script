function updateFunctions()
    for _, child in ipairs(functionsScrolling:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end
    
    if currentModule == "COMBAT" then
        createToggle("Aimbot", function(on) features.aimbot = on end)
        createSlider("Скорость аима", 0.1, 1, 0.5, function(val) features.aimbotSpeed = val end, "")
        createSlider("FOV", 30, 180, 90, function(val) features.aimbotFOV = val end, "°")
        createToggle("Team Check", function(on) features.teamCheck = on end)
        
    elseif currentModule == "MOVEMENT" then
        createToggle("Fly", toggleFly)
        createSlider("Скорость полета", 10, 200, 50, function(val) features.flySpeed = val end, "")
        createToggle("Noclip", function(on) features.noclip = on end)
        createToggle("Inf Jump", function(on) features.infJump = on end)
        createToggle("Speed", function(on) features.speedEnabled = on end)
        createSlider("Speed Power", 10, 200, 50, function(val) features.speedPower = val end, "")
        createToggle("Jump Power", function(on) features.jumpEnabled = on end)
        createSlider("Jump Power", 10, 200, 100, function(val) features.jumpPower = val end, "")
        
    elseif currentModule == "VISUALS" then
        createToggle("Fullbright", setFullbright)
        createToggle("Blur", setBlur)
        createToggle("No Fog", setNoFog)
        
    elseif currentModule == "PLAYER" then
        createToggle("F+Click TP", function(on) features.clickTp = on end)
        createToggle("God Mode", function(on) features.godMode = on end)
        createToggle("Infinite Ammo", function(on) features.infiniteAmmo = on end)
        
        local killBtn = Instance.new("TextButton")
        killBtn.Size = UDim2.new(1, 0, 0, 40)
        killBtn.BackgroundColor3 = colors.danger
        killBtn.Text = "KILL YOURSELF"
        killBtn.TextColor3 = Color3.new(1,1,1)
        killBtn.TextSize = 14
        killBtn.Font = Enum.Font.GothamBold
        killBtn.Parent = functionsScrolling
        
        local killCorner = Instance.new("UICorner")
        killCorner.CornerRadius = UDim.new(0, 8)
        killCorner.Parent = killBtn
        
        killBtn.MouseButton1Click:Connect(function()
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                player.Character.Humanoid.Health = 0
            end
        end)
        
    elseif currentModule == "ESP" then
        createToggle("ESP", function(on) features.espEnabled = on end)
        
    elseif currentModule == "MISC" then
        createToggle("Particles 3D", toggleParticles)
        createToggle("Auto Attack", function(on) features.autoAttack = on end)
        createSlider("Attack Range", 5, 50, 20, function(val) features.autoAttackRange = val end, "")
        
        -- КНОПКА UNHOOK (полная выгрузка)
        local unhookBtn = Instance.new("TextButton")
        unhookBtn.Size = UDim2.new(1, 0, 0, 45)
        unhookBtn.BackgroundColor3 = colors.danger
        unhookBtn.Text = "🔌 UNHOOK (ПОЛНАЯ ВЫГРУЗКА)"
        unhookBtn.TextColor3 = Color3.new(1, 1, 1)
        unhookBtn.TextSize = 14
        unhookBtn.Font = Enum.Font.GothamBold
        unhookBtn.Parent = functionsScrolling
        
        local unhookCorner = Instance.new("UICorner")
        unhookCorner.CornerRadius = UDim.new(0, 8)
        unhookCorner.Parent = unhookBtn
        
        unhookBtn.MouseButton1Click:Connect(function()
            unhook()
        end)
        
    elseif currentModule == "TELEPORT" then
        local tpInput = Instance.new("TextBox")
        tpInput.BackgroundColor3 = colors.panelLight
        tpInput.PlaceholderText = "Ник игрока"
        tpInput.PlaceholderColor3 = colors.textDim
        tpInput.Text = ""
        tpInput.TextColor3 = colors.text
        tpInput.Size = UDim2.new(1, 0, 0, 40)
        tpInput.Parent = functionsScrolling
        
        local tpCorner = Instance.new("UICorner")
        tpCorner.CornerRadius = UDim.new(0, 8)
        tpCorner.Parent = tpInput
        
        local tpBtn = Instance.new("TextButton")
        tpBtn.BackgroundColor3 = colors.accent
        tpBtn.Size = UDim2.new(1, 0, 0, 40)
        tpBtn.Text = "ТЕЛЕПОРТ К ИГРОКУ"
        tpBtn.TextColor3 = Color3.new(1,1,1)
        tpBtn.TextSize = 14
        tpBtn.Font = Enum.Font.GothamBold
        tpBtn.Parent = functionsScrolling
        
        local tpBtnCorner = Instance.new("UICorner")
        tpBtnCorner.CornerRadius = UDim.new(0, 8)
        tpBtnCorner.Parent = tpBtn
        
        tpBtn.MouseButton1Click:Connect(function()
            local targetName = tpInput.Text
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Name:lower():find(targetName:lower()) or p.DisplayName:lower():find(targetName:lower()) then
                    if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        player.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                    end
                    break
                end
            end
        end)
        
    elseif currentModule == "THEME" then
        createSlider("Затемнение фона", 0, 1, 0.7, function(val) bgDim.BackgroundTransparency = val end, "")
    end
end

-- Инициализация
updateFunctions()

-- ===== ГОРЯЧИЕ КЛАВИШИ =====
UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if input.KeyCode == Enum.KeyCode.F8 then
        unhook()
        return
    end
    
    if input.KeyCode == Enum.KeyCode.M then
        uiContainer.Visible = not uiContainer.Visible
        bgDim.Visible = uiContainer.Visible
        return
    end
    
    if input.KeyCode == Enum.KeyCode.Insert then
        uiContainer.Visible = not uiContainer.Visible
        bgDim.Visible = uiContainer.Visible
    end
end)

