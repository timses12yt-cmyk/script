-- Функция создания кнопки модуля
local function createModuleButton(name)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "Btn"
    btn.Size = UDim2.new(1, -20, 0, 45)
    btn.BackgroundColor3 = (currentModule == name) and colors.accent or colors.panelLight
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 1004
    btn.Parent = modulesScrolling
    
    -- Закругление
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    -- Текст
    local txt = Instance.new("TextLabel")
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.GothamBold
    txt.Text = name
    txt.TextColor3 = (currentModule == name) and Color3.new(1, 1, 1) or colors.text
    txt.TextSize = 15
    txt.Position = UDim2.new(0, 15, 0, 0)
    txt.Size = UDim2.new(1, -30, 1, 0)
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.ZIndex = 1005
    txt.Parent = btn
    
    -- Индикатор
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 4, 1, -10)
    indicator.Position = UDim2.new(1, -10, 0, 5)
    indicator.BackgroundColor3 = (currentModule == name) and Color3.fromRGB(255, 255, 255) or colors.textDim
    indicator.BorderSizePixel = 0
    indicator.ZIndex = 1005
    indicator.Parent = btn
    
    local indCorner = Instance.new("UICorner")
    indCorner.CornerRadius = UDim.new(0, 2)
    indCorner.Parent = indicator
    
    btn.MouseButton1Click:Connect(function()
        -- Обновляем все кнопки
        for _, child in ipairs(modulesScrolling:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = colors.panelLight
                child.TextLabel.TextColor3 = colors.text
                child.Frame.BackgroundColor3 = colors.textDim
            end
        end
        
        -- Активируем текущую
        btn.BackgroundColor3 = colors.accent
        btn.TextLabel.TextColor3 = Color3.new(1, 1, 1)
        btn.Frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        
        currentModule = name
        functionsTitle.Text = "▸ " .. name
        updateFunctions()
    end)
    
    return btn
end

-- Функция создания кнопки-переключателя
local function createToggleButton(text, default, callback)
    local btn = Instance.new("TextButton")
    btn.Name = text .. "Btn"
    btn.Size = UDim2.new(1, 0, 0, 40)
    btn.BackgroundColor3 = colors.panelLight
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.ZIndex = 1004
    btn.Parent = functionsScrolling

    -- Закругление
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn

    -- Текст
    local txt = Instance.new("TextLabel")
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.Gotham
    txt.Text = text
    txt.TextColor3 = colors.text
    txt.TextSize = 14
    txt.Position = UDim2.new(0, 15, 0, 0)
    txt.Size = UDim2.new(1, -70, 1, 0)
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.ZIndex = 1005
    txt.Parent = btn

    -- Статус
    local status = Instance.new("TextLabel")
    status.BackgroundTransparency = 1
    status.Font = Enum.Font.GothamBold
    status.Text = default and "ON" or "OFF"
    status.TextColor3 = default and colors.toggleOn or colors.textDim
    status.TextSize = 12
    status.Position = UDim2.new(1, -55, 0, 0)
    status.Size = UDim2.new(0, 50, 1, 0)
    status.TextXAlignment = Enum.TextXAlignment.Right
    status.ZIndex = 1005
    status.Parent = btn

    local enabled = default or false
    
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            btn.BackgroundColor3 = colors.accent
            status.Text = "ON"
            status.TextColor3 = colors.toggleOn
        else
            btn.BackgroundColor3 = colors.panelLight
            status.Text = "OFF"
            status.TextColor3 = colors.textDim
        end
        
        if callback then
            callback(enabled)
        end
    end)

    return {btn = btn, txt = txt, status = status, enabled = enabled}
end

-- Функция создания слайдера
local function createSlider(text, min, max, default, callback, suffix)
    suffix = suffix or ""
    local container = Instance.new("Frame")
    container.Name = text .. "Slider"
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 50)
    container.ZIndex = 1004
    container.Parent = functionsScrolling

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.Text = text
    label.TextColor3 = colors.text
    label.TextSize = 14
    label.Position = UDim2.new(0, 5, 0, 0)
    label.Size = UDim2.new(1, -70, 0, 22)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 1005
    label.Parent = container

    local valueLabel = Instance.new("TextLabel")
    valueLabel.BackgroundTransparency = 1
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.Text = tostring(default) .. suffix
    valueLabel.TextColor3 = colors.accentLight
    valueLabel.TextSize = 14
    valueLabel.Position = UDim2.new(1, -70, 0, 0)
    valueLabel.Size = UDim2.new(0, 70, 0, 22)
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right
    valueLabel.ZIndex = 1005
    valueLabel.Parent = container

    local sliderBg = Instance.new("Frame")
    sliderBg.BackgroundColor3 = colors.panelLight
    sliderBg.Position = UDim2.new(0, 5, 0, 28)
    sliderBg.Size = UDim2.new(1, -10, 0, 6)
    sliderBg.ZIndex = 1004
    sliderBg.Parent = container

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(0, 3)
    bgCorner.Parent = sliderBg

    local slider = Instance.new("Frame")
    slider.BackgroundColor3 = colors.accentLight
    slider.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    slider.ZIndex = 1005
    slider.Parent = sliderBg

    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 3)
    sliderCorner.Parent = slider

    local dragButton = Instance.new("TextButton")
    dragButton.BackgroundTransparency = 1
    dragButton.Size = UDim2.new(1, 0, 1, 0)
    dragButton.Text = ""
    dragButton.ZIndex = 1006
    dragButton.Parent = sliderBg

    local value = default
    local dragging = false

    dragButton.MouseButton1Down:Connect(function()
        dragging = true
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local mousePos = UIS:GetMouseLocation()
            local absPos = sliderBg.AbsolutePosition
            local size = sliderBg.AbsoluteSize.X
            
            local relative = math.clamp((mousePos.X - absPos.X) / size, 0, 1)
            slider:TweenSize(UDim2.new(relative, 0, 1, 0), "Out", "Quad", 0.1, true)
            
            value = min + (max - min) * relative
            value = math.floor(value * 100) / 100
            valueLabel.Text = tostring(value) .. suffix
            
            if callback then
                callback(value)
            end
        end
    end)

    return container
end

-- Функция создания дропдауна
local function createDropdown(text, options, default, callback)
    local container = Instance.new("Frame")
    container.Name = text .. "Dropdown"
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 50)
    container.ZIndex = 1004
    container.Parent = functionsScrolling

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.Text = text
    label.TextColor3 = colors.text
    label.TextSize = 14
    label.Position = UDim2.new(0, 5, 0, 0)
    label.Size = UDim2.new(1, -10, 0, 22)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 1005
    label.Parent = container

    local selectBtn = Instance.new("TextButton")
    selectBtn.BackgroundColor3 = colors.panelLight
    selectBtn.Position = UDim2.new(0, 5, 0, 25)
    selectBtn.Size = UDim2.new(1, -10, 0, 25)
    selectBtn.Text = default or options[1]
    selectBtn.TextColor3 = colors.text
    selectBtn.TextSize = 13
    selectBtn.ZIndex = 1006
    selectBtn.Parent = container

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = selectBtn

    local currentIndex = 1
    for i, opt in ipairs(options) do
        if opt == default then
            currentIndex = i
            break
        end
    end

    selectBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex % #options + 1
        selectBtn.Text = options[currentIndex]
        if callback then
            callback(options[currentIndex])
        end
    end)

    return selectBtn
end

