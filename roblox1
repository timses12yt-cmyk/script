UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if isSettingBind and input.UserInputType == Enum.UserInputType.Keyboard then
        local key = input.KeyCode
        if key ~= Enum.KeyCode.Unknown then
            binds[currentBindName] = {
                key = key,
                func = currentBindFunction
            }
            
            if bindButtons[currentBindName] then
                bindButtons[currentBindName].Text = string.format("[%s]", tostring(key):gsub("Enum.KeyCode.", ""))
            end
            
            saveConfig()
            
            isSettingBind = false
            currentBindFunction = nil
            currentBindName = nil
            if bindGui then bindGui:Destroy() bindGui = nil end
        end
    else
        for name, bind in pairs(binds) do
            if input.KeyCode == bind.key then
                bind.func()
                updateFunctions()
            end
        end
    end
end)

