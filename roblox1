-- PARTICLES
local particleConnection = nil
local particles = {}

local function createParticle()
    if not player.Character then return end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local angle = math.random() * 2 * math.pi
    local radius = math.random(10, particleSettings.spread)
    local height = math.random(-particleSettings.spread/2, particleSettings.spread/2)
    
    local spawnPos = hrp.Position + Vector3.new(
        math.cos(angle) * radius,
        height + 5,
        math.sin(angle) * radius
    )
    
    local color = colors.accentLight
    
    local ball = Instance.new("Part")
    ball.Size = Vector3.new(particleSettings.size, particleSettings.size, particleSettings.size)
    ball.Position = spawnPos
    ball.Anchored = false
    ball.CanCollide = false
    ball.Transparency = 0.2
    ball.BrickColor = BrickColor.new(color)
    ball.Material = Enum.Material.Neon
    ball.Shape = Enum.PartType.Ball
    ball.Parent = Workspace
    
    local glow = Instance.new("Part")
    glow.Size = Vector3.new(particleSettings.size * 2, particleSettings.size * 2, particleSettings.size * 2)
    glow.Position = spawnPos
    glow.Anchored = false
    glow.CanCollide = false
    glow.Transparency = 0.6
    glow.BrickColor = BrickColor.new(color)
    glow.Material = Enum.Material.Neon
    glow.Shape = Enum.PartType.Ball
    glow.Parent = Workspace
    
    local light = Instance.new("PointLight")
    light.Parent = ball
    light.Color = color
    light.Range = particleSettings.size * 15
    light.Brightness = 2
    
    local startPos = spawnPos
    local time = 0
    local connection
    
    connection = RunService.Heartbeat:Connect(function(dt)
        if not ball or not ball.Parent then
            if connection then connection:Disconnect() end
            return
        end
        
        time = time + dt
        
        local offsetX = math.sin(time * 2) * 2
        local offsetY = math.sin(time * 1.5) * 1.5
        local offsetZ = math.cos(time * 2) * 2
        
        ball.Position = startPos + Vector3.new(offsetX, offsetY, offsetZ)
        glow.Position = ball.Position
        light.Parent = ball
    end)
    
    local particle = {
        ball = ball,
        glow = glow,
        light = light,
        connection = connection
    }
    table.insert(particles, particle)
    
    Debris:AddItem(ball, particleSettings.lifetime)
    Debris:AddItem(glow, particleSettings.lifetime)
    Debris:AddItem(light, particleSettings.lifetime)
end

local function updateParticles()
    for _, particle in ipairs(particles) do
        pcall(function()
            if particle.connection then particle.connection:Disconnect() end
            if particle.ball and particle.ball.Parent then particle.ball:Destroy() end
            if particle.glow and particle.glow.Parent then particle.glow:Destroy() end
            if particle.light and particle.light.Parent then particle.light:Destroy() end
        end)
    end
    particles = {}
    
    if particleConnection then 
        particleConnection:Disconnect() 
        particleConnection = nil 
    end
    
    if particlesEnabled then
        for i = 1, particleSettings.count do
            createParticle()
            wait(0.05)
        end
        
        particleConnection = RunService.Heartbeat:Connect(function()
            if math.random() < 0.1 then
                createParticle()
            end
        end)
    end
end

