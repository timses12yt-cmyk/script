local function createParticles()
    clearParticles()
    
    for i = 1, particleSettings.count do
        local p = Instance.new("Part")
        p.Shape = Enum.PartType.Ball
        p.Size = Vector3.new(particleSettings.size, particleSettings.size, particleSettings.size)
        p.Material = Enum.Material.Neon
        p.Color = colors.accentLight
        p.Anchored = true
        p.CanCollide = false
        p.Parent = Workspace
        
        table.insert(particles, p)
        table.insert(angles, math.random() * math.pi * 2)
    end
    
    particleTime = 0
end

RunService.RenderStepped:Connect(function(dt)
    if not particlesEnabled then return end
    
    local targetChar
    if particlesTarget then
        local plr = getClosestPlayer()
        if plr then targetChar = plr.Character end
    else
        targetChar = player.Character
    end
    
    if not targetChar then return end
    
    local root = targetChar:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    particleTime = particleTime + dt
    
    for i, p in ipairs(particles) do
        angles[i] = angles[i] + dt * 2
        
        if particleSettings.mode == "Круговой" then
            local x = math.cos(angles[i]) * 8
            local z = math.sin(angles[i]) * 8
            local target = root.Position + Vector3.new(x, 1, z)
            p.Position = p.Position:Lerp(target, 0.06)
            
        elseif particleSettings.mode == "Вертикальный" then
            local x = math.cos(angles[i]) * 8
            local z = math.sin(angles[i]) * 8
            local yOffset = math.sin(particleTime * 2 + i) * 3
            local target = root.Position + Vector3.new(x, 1 + yOffset, z)
            p.Position = p.Position:Lerp(target, 0.06)
            
        elseif particleSettings.mode == "Крест" then
            local angle = angles[i]
            local radius = 8
            
            if i % 2 == 0 then
                local x = math.cos(angle) * radius
                local z = math.sin(angle) * radius
                local target = root.Position + Vector3.new(x, 1, z)
                p.Position = p.Position:Lerp(target, 0.06)
            else
                local x = math.cos(angle + math.pi/4) * radius
                local z = math.sin(angle + math.pi/4) * radius
                local target = root.Position + Vector3.new(x, 1, z)
                p.Position = p.Position:Lerp(target, 0.06)
            end
            
        elseif particleSettings.mode == "Вихрь" then
            local radius = 5 + math.sin(particleTime * 3 + i) * 3
            local height = math.sin(particleTime * 2 + i) * 4
            local x = math.cos(angles[i] + particleTime) * radius
            local z = math.sin(angles[i] + particleTime) * radius
            local target = root.Position + Vector3.new(x, 2 + height, z)
            p.Position = p.Position:Lerp(target, 0.06)
            
        elseif particleSettings.mode == "Сфера" then
            local theta = angles[i] + particleTime
            local phi = angles[i] * 2
            local radius = 6
            local x = math.sin(theta) * math.cos(phi) * radius
            local y = math.sin(theta) * math.sin(phi) * radius
            local z = math.cos(theta) * radius
            local target = root.Position + Vector3.new(x, y + 2, z)
            p.Position = p.Position:Lerp(target, 0.06)
        end
    end
end)
