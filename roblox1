    label.Position = UDim2.new(0, 5, 0, 0)
    label.Size = UDim2.new(1, -10, 0, 22)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    local selectBtn = Instance.new("TextButton")
    selectBtn.BackgroundColor3 = colors.panelLight
    selectBtn.Position = UDim2.new(0, 5, 0, 25)
    selectBtn.Size = UDim2.new(1, -10, 0, 25)
    selectBtn.Text = default or options[1]
    selectBtn.TextColor3 = colors.text
    selectBtn.TextSize = 13
    selectBtn.Parent = container

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = selectBtn

    local currentIndex = 1
    for i, opt in ipairs(options) do
        if opt == default then currentIndex = i break end
    end

    selectBtn.MouseButton1Click:Connect(function()
        currentIndex = currentIndex % #options + 1
        selectBtn.Text = options[currentIndex]
        callback(options[currentIndex])
    end)

    return selectBtn
end

