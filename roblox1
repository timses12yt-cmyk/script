local testConnection = nil

local function doTestLoop()
    if testConnection then testConnection:Disconnect() end
    
    testConnection = RunService.Heartbeat:Connect(function()
        if not testEnabled or not player.Character then return end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local closest = nil
        local shortest = math.huge
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = p
                end
            end
        end
        
        if closest then
            local targetPos = closest.Character.HumanoidRootPart.Position
            local lookVector = closest.Character.HumanoidRootPart.CFrame.LookVector
            
            local time = tick() % 0.6
            if time < 0.3 then
                hrp.CFrame = CFrame.new(targetPos - lookVector * 3, targetPos)
            else
                hrp.CFrame = CFrame.new(targetPos - lookVector * 1, targetPos)
            end
        end
    end)
end

local killAllConnection = nil
local killAllTarget = nil

local function doKillAllLoop()
    if killAllConnection then killAllConnection:Disconnect() end
    
    killAllConnection = RunService.Heartbeat:Connect(function()
        if not killAllEnabled or not player.Character then return end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local closest = nil
        local shortest = math.huge
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if friends[p.UserId] then continue end
                local dist = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = p
                end
            end
        end
        
        if closest then
            killAllTarget = closest
            local targetPos = closest.Character.HumanoidRootPart.Position
            local lookVector = closest.Character.HumanoidRootPart.CFrame.LookVector
            
            hrp.CFrame = CFrame.new(targetPos - lookVector * 1.5, targetPos)
            
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local camera = Workspace.CurrentCamera
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, closest.Character.Head.Position)
            end
        end
    end)
end

local escapeConnection = nil
local escapeEnabled = false
local escapeDistance = 15

local function doEscapeLoop()
    if escapeConnection then escapeConnection:Disconnect() end
    
    escapeConnection = RunService.Heartbeat:Connect(function()
        if not testEnabled or not escapeEnabled or not player.Character then return end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local closest = nil
        local shortest = math.huge
        
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (hrp.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    closest = p
                end
            end
        end
        
        if closest then
            local targetPos = closest.Character.HumanoidRootPart.Position
            local direction = (hrp.Position - targetPos).Unit
            
            if shortest < escapeDistance then
                hrp.CFrame = CFrame.new(targetPos + direction * escapeDistance, targetPos + direction * escapeDistance * 2)
            else
                local lookVector = closest.Character.HumanoidRootPart.CFrame.LookVector
                local time = tick() % 0.6
                if time < 0.3 then
                    hrp.CFrame = CFrame.new(targetPos - lookVector * 3, targetPos)
                else
                    hrp.CFrame = CFrame.new(targetPos - lookVector * 1, targetPos)
                end
            end
        end
    end)
end

local function updateInvisibility()
    if not player.Character then return end
    
    if invisibleEnabled then
        for _, part in ipairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 1
            end
        end
    else
        for _, part in ipairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0
            end
        end
    end
end

local flyConnection = nil
local function updateFly()
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    
    if (flyEnabled or turboFlyEnabled) and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            flyConnection = RunService.Heartbeat:Connect(function()
                if not (flyEnabled or turboFlyEnabled) or not player.Character then return end
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                
                local moveDir = Vector3.new()
                local cam = Workspace.CurrentCamera.CFrame
                
                if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end
                
                local currentSpeed = turboFlyEnabled and turboFlySpeed or flySpeed
                hrp.Velocity = moveDir * currentSpeed
            end)
        end
    end
end

