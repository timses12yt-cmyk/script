UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    -- F8 - полная выгрузка (unhook)
    if input.KeyCode == Enum.KeyCode.F8 then
        gui:Destroy()
        print("✅ Nez0x UI выгружен")
        return
    end
    
    -- M - свернуть/развернуть
    if input.KeyCode == Enum.KeyCode.M then
        if uiContainer.Visible then
            -- Сворачиваем
            uiContainer.Visible = false
            bgDim.Visible = false
        else
            -- Разворачиваем
            uiContainer.Visible = true
            bgDim.Visible = true
        end
        return
    end
    
    -- Insert - альтернативное открытие/закрытие
    if input.KeyCode == Enum.KeyCode.Insert then
        uiContainer.Visible = not uiContainer.Visible
        bgDim.Visible = uiContainer.Visible
    end
end)

