        end)
        
    elseif currentModule == "THEME" then
        createSlider("Затемнение фона", 0, 1, function() return bgTransparency end, function(v) bgTransparency = v bgDim.BackgroundTransparency = v end, "")
        
        -- Слайдер размера GUI
        createSlider("Размер GUI", minSize, maxSize, function() return guiSize end, function(v) updateGuiSize(v) saveConfig() end, "x")
        
        -- Готовые темы
        local themeNote = Instance.new("TextLabel")
        themeNote.Size = UDim2.new(1, 0, 0, 30 * guiSize)
        themeNote.BackgroundTransparency = 1
        themeNote.Text = "🎨 ГОТОВЫЕ ТЕМЫ"
        themeNote.TextColor3 = colors.accentLight
        themeNote.TextSize = 16 * guiSize
        themeNote.Font = Enum.Font.GothamBold
        themeNote.Parent = functionsScrolling
        
        for themeName, themeColors in pairs(themes) do
            local themeBtn = Instance.new("TextButton")
            themeBtn.Size = UDim2.new(1, 0, 0, 40 * guiSize)
            themeBtn.BackgroundColor3 = themeColors.accent
            themeBtn.Text = themeName
            themeBtn.TextColor3 = Color3.new(1,1,1)
            themeBtn.TextSize = 14 * guiSize
            themeBtn.Font = Enum.Font.GothamBold
            themeBtn.Parent = functionsScrolling
            
            local themeCorner = Instance.new("UICorner")
            themeCorner.CornerRadius = UDim.new(0, 8 * guiSize)
            themeCorner.Parent = themeBtn
            
            themeBtn.MouseButton1Click:Connect(function()
                -- Применяем тему
                for k, v in pairs(themeColors) do
                    colors[k] = v
                end
                
                -- Обновляем интерфейс
                modulesPanel.BackgroundColor3 = colors.panel
                functionsPanel.BackgroundColor3 = colors.panel
                bgDim.BackgroundColor3 = colors.background
                
                -- Обновляем цвета текста во всем UI
                modulesTitle.TextColor3 = colors.accentLight
                functionsTitle.TextColor3 = colors.accentLight
                
                -- Обновляем все кнопки модулей
                for _, child in ipairs(modulesScrolling:GetChildren()) do
                    if child:IsA("TextButton") then
                        if child.TextLabel.Text == currentModule then
                            child.BackgroundColor3 = colors.accent
                            child.TextLabel.TextColor3 = Color3.new(1,1,1)
                        else
                            child.BackgroundColor3 = colors.panelLight
                            child.TextLabel.TextColor3 = colors.text
                        end
                        child.Frame.BackgroundColor3 = colors.textDim
                    end
                end
                
                saveConfig()
                updateFunctions()
            end)
        end
        
        -- Кнопка сброса на дефолт
        local resetBtn = Instance.new("TextButton")
        resetBtn.Size = UDim2.new(1, 0, 0, 40 * guiSize)
        resetBtn.BackgroundColor3 = colors.accent
        resetBtn.Text = "🔄 СБРОСИТЬ НА СТАНДАРТНУЮ"
        resetBtn.TextColor3 = Color3.new(1,1,1)
        resetBtn.TextSize = 14 * guiSize
        resetBtn.Font = Enum.Font.GothamBold
        resetBtn.Parent = functionsScrolling
        
        local resetCorner = Instance.new("UICorner")
        resetCorner.CornerRadius = UDim.new(0, 8 * guiSize)
        resetCorner.Parent = resetBtn
        
        resetBtn.MouseButton1Click:Connect(function()
            -- Сбрасываем на дефолтные цвета
            for k, v in pairs(defaultColors) do
                colors[k] = v
            end
            
            modulesPanel.BackgroundColor3 = colors.panel
            functionsPanel.BackgroundColor3 = colors.panel
            bgDim.BackgroundColor3 = colors.background
            modulesTitle.TextColor3 = colors.accentLight
            functionsTitle.TextColor3 = colors.accentLight
            
            -- Обновляем кнопки модулей
            for _, child in ipairs(modulesScrolling:GetChildren()) do
                if child:IsA("TextButton") then
                    if child.TextLabel.Text == currentModule then
                        child.BackgroundColor3 = colors.accent
                        child.TextLabel.TextColor3 = Color3.new(1,1,1)
                    else
                        child.BackgroundColor3 = colors.panelLight
                        child.TextLabel.TextColor3 = colors.text
                    end
                    child.Frame.BackgroundColor3 = colors.textDim
                end
            end
            
            saveConfig()
            updateFunctions()
        end)
    end
end

